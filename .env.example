# Copy this file to .env on your VPS and fill in your values.
# Never commit the real .env file — it is listed in .gitignore.

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://smartlearn:yourpassword@localhost:5432/smartlearn

# ── Admin dashboard ───────────────────────────────────────────────────────────
# Password to log in at /admin — choose something strong
ADMIN_PASSWORD=change_me_to_something_strong

# ── API server ────────────────────────────────────────────────────────────────
# Port the Express API listens on (Nginx proxies /api/ to this)
PORT=8080

# Node environment
NODE_ENV=production

# ── Email / SMTP Server ───────────────────────────────────────────────────────
# Connection details for the aaPanel (or external) SMTP mail server
SMTP_HOST=mail.smartlearn.education
SMTP_PORT=465
SMTP_USER=contact@smartlearn.education
SMTP_PASSWORD=your_email_password_here
